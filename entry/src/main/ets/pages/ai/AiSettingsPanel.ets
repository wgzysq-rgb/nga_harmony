  // ============================================================
  // AI 场景 Prompt 模板
  // ============================================================

  /** 构建场景 Prompt 模板区域。 */
  @Builder
  ScenarioSection() {
    Column() {
      // Section header
      Text('Prompt 模板')
        .fontSize(14)
        .fontColor(AppColors.textPrimary)
        .fontWeight(FontWeight.Medium)
        .width('92%')
        .margin({ top: 20, bottom: 2 })

      Text('自定义各 AI 功能的角色行为和输出风格，注入数据由系统自动拼接')
        .fontSize(11)
        .fontColor(AppColors.textTertiary)
        .lineHeight(16)
        .width('92%')
        .margin({ bottom: 8, top: 2 })

      this.ScenarioCard(AiScenario.POST_SUMMARY)
      this.ScenarioCard(AiScenario.USER_ANALYSIS)
    }
    .width('100%')
    .alignItems(HorizontalAlign.Center)
  }

  /**
   * 构建单个场景卡片。
   *
   * @param scenario - 场景标识
   */
  @Builder
  ScenarioCard(scenario: string) {
    Column() {
      this.ScenarioCardHeader(scenario)

      if (this.expandedScenario === scenario) {
        Divider().color(AppColors.separator).width('100%').margin({ bottom: 4 })
        this.ScenarioCardBody(scenario)
      }
    }
    .width('92%')
    .alignItems(HorizontalAlign.Start)
    .backgroundColor(AppColors.bgTertiary)
    .borderRadius(12)
    .margin({ top: 8 })
  }

  /**
   * 场景卡片头部。
   *
   * @param scenario - 场景标识
   */
  @Builder
  ScenarioCardHeader(scenario: string) {
    Row() {
      Image(this.scenarioIcon(scenario))
        .width(20)
        .height(20)
        .fillColor(AppColors.textSecondary)
        .margin({ right: 10 })

      Column() {
        Text(SCENARIO_META[scenario].name)
          .fontSize(15)
          .fontColor(AppColors.textPrimary)
          .fontWeight(FontWeight.Medium)
          .maxLines(1)
          .textOverflow({ overflow: TextOverflow.Ellipsis })

        Text(SCENARIO_META[scenario].desc)
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
          .lineHeight(16)
          .maxLines(2)
          .textOverflow({ overflow: TextOverflow.Ellipsis })
          .margin({ top: 2 })
      }
      .layoutWeight(1)
      .alignItems(HorizontalAlign.Start)

      // Status badge
      this.ScenarioBadge(scenario)

      // Expand chevron
      Text(this.expandedScenario === scenario ? '▾' : '▸')
        .fontSize(14)
        .fontColor(AppColors.chevron)
        .margin({ left: 8 })
        .flexShrink(0)
    }
    .width('100%')
    .padding({ left: 14, right: 14, top: 12, bottom: 12 })
    .onClick(() => {
      if (this.expandedScenario === scenario) {
        this.expandedScenario = ''
      } else {
        this.doExpandScenario(scenario)
      }
    })
  }

  /**
   * 展开场景卡片并初始化编辑缓冲。
   *
   * @param scenario - 场景标识
   */
  private doExpandScenario(scenario: string): void {
    this.expandedScenario = scenario
    this.editScenarioPromptInput = appStore.getScenarioPrompt(scenario)
    this.showDataPreview = false
  }

  /**
   * 场景状态徽章。
   *
   * @param scenario - 场景标识
   */
  @Builder
  ScenarioBadge(scenario: string) {
    Text(this.scenarioPromptVersion > -1 && this.isScenarioCustom(scenario) ? '自定义' : '默认')
      .fontSize(11)
      .fontColor(this.scenarioPromptVersion > -1 && this.isScenarioCustom(scenario) ? AppColors.primary : AppColors.textTertiary)
      .padding({ left: 8, right: 8, top: 2, bottom: 2 })
      .border({
        width: 1,
        color: this.scenarioPromptVersion > -1 && this.isScenarioCustom(scenario) ? AppColors.primary : AppColors.textTertiary,
        style: BorderStyle.Solid
      })
      .borderRadius(10)
  }

  /**
   * 判断指定场景是否已自定义。
   *
   * 与 DEFAULT_SYSTEM_PROMPTS 比对，内容相同时不视为自定义，
   * 防止 TextArea onChange 回写默认文本导致场景被误判。
   *
   * @param scenario - 场景标识
   * @returns 是否已自定义
   */
  private isScenarioCustom(scenario: string): boolean {
    const custom: string = (appStore.settings.scenarioSystemPrompts[scenario] ?? '').trim()
    if (custom.length === 0) {
      return false
    }
    const defaultPrompt: string = DEFAULT_SYSTEM_PROMPTS[scenario] ?? ''
    return custom !== defaultPrompt.trim()
  }

  /**
   * 获取场景对应的图标资源。
   *
   * @param scenario - 场景标识
   * @returns 图标资源引用
   */
  private scenarioIcon(scenario: string): Resource {
    if (scenario === AiScenario.POST_SUMMARY) {
      return $r('app.media.icon_ai_summary')
    }
    return $r('app.media.icon_ai_profile')
  }

  /**
   * 场景卡片展开体。
   *
   * @param scenario - 场景标识
   */
  @Builder
  ScenarioCardBody(scenario: string) {
    Column() {
      // System prompt label
      Text('系统提示词')
        .fontSize(13)
        .fontColor(AppColors.textSecondary)
        .width('100%')
        .margin({ bottom: 4 })

      // TextArea
      TextArea({ text: this.editScenarioPromptInput, placeholder: '在此输入系统提示词…' })
        .onChange((value: string): void => {
          this.editScenarioPromptInput = value
          appStore.setScenarioPrompt(scenario, value)
          this.scenarioPromptVersion++
        })
        .width('100%')
        .height(150)
        .backgroundColor(AppColors.bgSecondary)
        .borderRadius(8)
        .fontSize(14)
        .padding({ left: 12, right: 12, top: 8, bottom: 8 })

      // Reset button + info
      Row() {
        if (this.scenarioPromptVersion > -1 && this.isScenarioCustom(scenario)) {
          Text('↺ 恢复默认')
            .fontSize(12)
            .fontColor(AppColors.textTertiary)
            .padding({ left: 10, right: 10, top: 4, bottom: 4 })
            .onClick(() => {
              appStore.resetScenarioPrompt(scenario)
              this.editScenarioPromptInput = appStore.getScenarioPrompt(scenario)
              this.scenarioPromptVersion++
            })
        }

        Blank()

        Text(this.editScenarioPromptInput.length.toString() + ' 字')
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
      }
      .width('100%')
      .margin({ top: 6, bottom: 10 })

      // Data preview toggle
      this.ScenarioDataPreview(scenario)
    }
    .width('100%')
    .alignItems(HorizontalAlign.Start)
    .padding({ left: 16, right: 16, top: 8, bottom: 16 })
  }

  /**
   * 注入数据预览区域。
   *
   * @param scenario - 场景标识
   */
  @Builder
  ScenarioDataPreview(scenario: string) {
    Column() {
      Row() {
        Text('ℹ️ 以下数据会自动注入到每次请求中')
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
          .lineHeight(16)
          .layoutWeight(1)

        Text(this.showDataPreview ? '收起 ▲' : '展开 ▼')
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
          .margin({ left: 8 })
      }
      .width('100%')
      .padding({ left: 10, right: 10, top: 6, bottom: 6 })
      .backgroundColor(AppColors.bgSecondary)
      .borderRadius(8)
      .onClick(() => {
        this.showDataPreview = !this.showDataPreview
      })

      if (this.showDataPreview) {
        Column() {
          ForEach(SCENARIO_INJECTED_FIELDS[scenario], (field: InjectedFieldInfo) => {
            Column() {
              Text(field.label)
                .fontSize(12)
                .fontColor(AppColors.textSecondary)
                .fontWeight(FontWeight.Medium)

              Text(field.example)
                .fontSize(12)
                .fontColor(AppColors.textTertiary)
                .fontStyle(FontStyle.Italic)
                .lineHeight(16)
                .margin({ top: 2 })
            }
            .width('100%')
            .alignItems(HorizontalAlign.Start)
            .padding({ left: 10, top: 4, bottom: 4 })
          }, (field: InjectedFieldInfo): string => field.label)
        }
        .width('100%')
        .alignItems(HorizontalAlign.Start)
        .padding({ top: 6, bottom: 8 })
        .backgroundColor(AppColors.bgSecondary)
        .borderRadius({ bottomLeft: 8, bottomRight: 8 })
      }
    }
    .width('100%')
    .alignItems(HorizontalAlign.Start)
    .margin({ top: 4 })
  }

  /**
   * 构建已有配置卡片。
   *
   * @param profile - AI 配置
   */
  @Builder
  ProfileCard(profile: AiProviderProfile) {
    Column() {
      this.ProfileCardHeader(profile)

      if (this.expandedProfileId === profile.id) {
        Divider().color(AppColors.separator).width('100%').margin({ bottom: 4 })
        this.ProfileCardBody()
      }
    }
    .width('92%')
    .backgroundColor(AppColors.bgTertiary)
    .borderRadius(12)
    .margin({ top: 8 })
  }

  /**
   * 构建配置卡片头部。
   *
   * @param profile - AI 配置
   */
  @Builder
  ProfileCardHeader(profile: AiProviderProfile) {
    Row() {
      Row() {
        Radio({ value: profile.id, group: 'aiProvider' })
          .checked(this.isActiveProfile(profile.id))
          .onChange((checked: boolean) => {
            if (checked) {
              appStore.setActiveAiProfile(profile.id)
              this.syncProfiles()
            }
          })
          .width(20)
          .height(20)
      }
      .width(36)
      .height(48)
      .justifyContent(FlexAlign.Center)

      Column() {
        Text(profile.name)
          .fontSize(15)
          .fontColor(AppColors.textPrimary)
          .fontWeight(FontWeight.Medium)
          .maxLines(1)
          .textOverflow({ overflow: TextOverflow.Ellipsis })

        Text(profile.endpoint)
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
          .margin({ top: 2 })
          .maxLines(1)
          .textOverflow({ overflow: TextOverflow.Ellipsis })
      }
      .alignItems(HorizontalAlign.Start)
      .layoutWeight(1)
      .onClick(() => {
        if (this.expandedProfileId === profile.id) {
          this.collapseCard()
        } else {
          this.expandCard(profile.id)
        }
      })

      Text('删除')
        .fontSize(12)
        .fontColor(AppColors.destructive)
        .padding({ left: 6, right: 6, top: 4, bottom: 4 })
        .onClick(() => {
          this.deleteProfile(profile.id)
        })
    }
    .width('100%')
    .padding({ left: 12, right: 8, top: 12, bottom: 12 })
  }

  /**
   * 公共表单字段 — 按操作顺序排列：方案名称、服务地址、API 密钥、
   * 模型名称（获取/手动输入）、联通测试及保存/取消按钮。
   *
   * 由 ProfileCardBody 和 NewProfileCard 共享，
   * 避免两处各维护一份相同的表单代码。
   */
  @Builder
  ProfileFormFields() {
    Column() {
      Text('方案名称')
        .fontSize(13)
        .fontColor(AppColors.textSecondary)
        .width('100%')
        .margin({ bottom: 4 })

      TextInput({ placeholder: '为这个方案起个名字', text: this.editNameInput })
        .onChange((v: string) => {
          this.editNameInput = v
        })
        .width('100%')
        .height(40)
        .backgroundColor(AppColors.bgSecondary)
        .borderRadius(8)
        .fontSize(14)
        .padding({ left: 12, right: 12 })
    }
    .width('100%')
    .margin({ bottom: 10 })

    Column() {
      Text('服务地址')
        .fontSize(13)
        .fontColor(AppColors.textSecondary)
        .width('100%')
        .margin({ bottom: 4 })

      TextInput({ placeholder: this.getEndpointPlaceholder(), text: this.editEndpointInput })
        .onChange((v: string) => {
          this.editEndpointInput = v
          this.fetchedModels = []
          this.invalidatePendingRequests()
        })
        .width('100%')
        .height(40)
        .backgroundColor(AppColors.bgSecondary)
        .borderRadius(8)
        .fontSize(14)
        .padding({ left: 12, right: 12 })
    }
    .width('100%')
    .margin({ bottom: 10 })

    Column() {
      Text('API 密钥')
        .fontSize(13)
        .fontColor(AppColors.textSecondary)
        .width('100%')
        .margin({ bottom: 4 })

      TextInput({ placeholder: this.getApiKeyPlaceholder(), text: this.editApiKeyInput })
        .type(InputType.Password)
        .onChange((v: string) => {
          this.editApiKeyInput = v
        })
        .width('100%')
        .height(40)
        .backgroundColor(AppColors.bgSecondary)
        .borderRadius(8)
        .fontSize(14)
        .padding({ left: 12, right: 12 })
    }
    .width('100%')
    .margin({ bottom: 10 })

    Row() {
      Column() {
        Text('模型名称')
          .fontSize(13)
          .fontColor(AppColors.textSecondary)
          .width('100%')
          .margin({ bottom: 4 })

        TextInput({ placeholder: this.getModelPlaceholder(), text: this.editModelInput })
          .onChange((v: string) => {
            this.editModelInput = v
          })
          .width('100%')
          .height(40)
          .backgroundColor(AppColors.bgSecondary)
          .borderRadius(8)
          .fontSize(14)
          .padding({ left: 12, right: 12 })
      }
      .layoutWeight(1)

      if (this.supportsCurrentModelList()) {
        Text(this.fetchingModels ? '获取中...' : '获取模型列表')
          .fontSize(12)
          .fontColor(this.fetchingModels ? AppColors.textTertiary : AppColors.primary)
          .padding({ left: 10, right: 10, top: 8, bottom: 8 })
          .margin({ left: 8, top: 18 })
          .border({
            width: 1,
            color: this.fetchingModels ? AppColors.textTertiary : AppColors.primary,
            style: BorderStyle.Solid
          })
          .borderRadius(6)
          .onClick(() => {
            this.fetchModels()
          })
      } else {
        Text('手动输入')
          .fontSize(12)
          .fontColor(AppColors.textTertiary)
          .padding({ left: 10, right: 10, top: 8, bottom: 8 })
          .margin({ left: 8, top: 18 })
          .border({
            width: 1,
            color: AppColors.textTertiary,
            style: BorderStyle.Solid
          })
          .borderRadius(6)
      }
    }
    .width('100%')
    .margin({ bottom: 4 })

    if (this.fetchedModels.length > 0) {
      Row() {
        ForEach(this.fetchedModels, (model: string) => {
          Text(model)
            .fontSize(12)
            .fontColor(this.editModelInput === model ? AppColors.white : AppColors.primary)
            .padding({ left: 10, right: 10, top: 4, bottom: 4 })
            .backgroundColor(this.editModelInput === model ? AppColors.primary : AppColors.primaryLight)
            .borderRadius(12)
            .margin({ right: 6, bottom: 4 })
            .onClick(() => {
              this.selectModel(model)
            })
        }, (model: string): string => model)
      }
      .width('100%')
      .margin({ bottom: 12 })
    }

    Row() {
      Column() {
        Text('流式输出')
          .fontSize(13)
          .fontColor(AppColors.textSecondary)
          .width('100%')
        Text('开启后 AI 结果会边生成边显示')
          .fontSize(11)
          .fontColor(AppColors.textTertiary)
          .width('100%')
          .margin({ top: 2 })
      }
      .layoutWeight(1)
      .alignItems(HorizontalAlign.Start)

      Toggle({ type: ToggleType.Switch, isOn: this.editStreamingInput })
        .onChange((v: boolean) => {
          this.editStreamingInput = v
        })
    }
    .width('100%')
    .height(46)
    .padding({ left: 12, right: 12 })
    .backgroundColor(AppColors.bgSecondary)
    .borderRadius(8)
    .alignItems(VerticalAlign.Center)
    .margin({ bottom: 10 })

    Row() {
      Text(this.testing ? '测试中...' : '测试连接')
        .fontSize(13)
        .fontColor(this.testing ? AppColors.textTertiary : AppColors.primary)
        .padding({ left: 16, right: 16, top: 8, bottom: 8 })
        .border({
          width: 1,
          color: this.testing ? AppColors.textTertiary : AppColors.primary,
          style: BorderStyle.Solid
        })
        .borderRadius(8)
        .onClick(() => {
          this.doTestConnection()
        })
    }
    .width('100%')
    .margin({ bottom: 6 })

    if (this.testResultMessage.length > 0) {
      Text(this.testResultMessage)
        .fontSize(12)
        .fontColor(this.testSuccess ? AppColors.success : AppColors.destructive)
        .margin({ bottom: 10 })
        .width('100%')
        .lineHeight(18)
    }

    Row() {
      Text('取消')
        .fontSize(14)
        .fontColor(AppColors.textSecondary)
        .layoutWeight(1)
        .height(38)
        .textAlign(TextAlign.Center)
        .onClick(() => {
          this.collapseCard()
        })

      Text('保存')
        .fontSize(14)
        .fontColor(AppColors.white)
        .layoutWeight(1)
        .height(38)
        .textAlign(TextAlign.Center)
        .backgroundColor(AppColors.primary)
        .borderRadius(10)
        .onClick(() => {
          this.saveProfile()
        })
    }
    .width('100%')
    .margin({ top: 4 })
  }

  /** 构建已存在配置的展开编辑区。 */
  @Builder
  ProfileCardBody() {
    Column() {
      this.ProfileFormFields()
    }
    .width('100%')
    .padding({ left: 16, right: 16, top: 8, bottom: 16 })
  }

  /** 新建方案卡片 */
  @Builder
  NewProfileCard() {
    Column() {
      Row() {
        Column() {
          Text(this.editNameInput.length > 0 ? this.editNameInput : '新建方案')
            .fontSize(15)
            .fontColor(AppColors.textPrimary)
            .fontWeight(FontWeight.Medium)
            .maxLines(1)

          if (this.editEndpointInput.length > 0) {
            Text(this.editEndpointInput)
              .fontSize(11)
              .fontColor(AppColors.textTertiary)
              .margin({ top: 2 })
              .maxLines(1)
              .textOverflow({ overflow: TextOverflow.Ellipsis })
          }
        }
        .alignItems(HorizontalAlign.Start)
        .layoutWeight(1)
        .onClick(() => {
          this.collapseCard()
        })

        Text('放弃')
          .fontSize(12)
          .fontColor(AppColors.textTertiary)
          .padding({ left: 6, right: 6, top: 4, bottom: 4 })
          .onClick(() => {
            this.collapseCard()
          })
      }
      .width('100%')
      .padding({ left: 16, right: 12, top: 12, bottom: 4 })

      Divider().color(AppColors.separator).width('100%').margin({ bottom: 4 })

      Column() {
        this.ProfileFormFields()
      }
      .width('100%')
      .padding({ left: 16, right: 16, top: 8, bottom: 16 })
    }
    .width('92%')
    .backgroundColor(AppColors.bgTertiary)
    .borderRadius(12)
    .margin({ top: 8 })
  }

  /** 构建添加 AI 服务按钮。 */
  @Builder
  AddButton() {
    Row() {
      Text('+ 添加 AI 服务')
        .fontSize(15)
        .fontColor(AppColors.primary)
        .fontWeight(FontWeight.Medium)
    }
    .width('92%')
    .height(44)
    .justifyContent(FlexAlign.Center)
    .backgroundColor(AppColors.bgTertiary)
    .borderRadius(12)
    .margin({ top: 8 })
    .onClick(() => {
      if (this.hasUnsavedEdit()) {
        this.showDiscardConfirm((): void => {
          this.showProviderPresetPicker()
        })
        return
      }
      this.showProviderPresetPicker()
    })
  }

  /** 构建空状态提示。 */
  @Builder
  EmptyHint() {
    Column() {
      Text('🤖')
        .fontSize(36)

      Text('还没有自定义 AI 配置')
        .fontSize(15)
        .fontColor(AppColors.textPrimary)
        .fontWeight(FontWeight.Medium)
        .margin({ top: 10 })

      Text('添加 DeepSeek、智谱GLM 等 AI 服务，\n让帖子总结和用户分析更快更智能')
        .fontSize(12)
        .fontColor(AppColors.textTertiary)
        .textAlign(TextAlign.Center)
        .margin({ top: 6 })
        .lineHeight(18)
    }
    .width('92%')
    .padding({ top: 28, bottom: 8 })
    .alignItems(HorizontalAlign.Center)
  }

