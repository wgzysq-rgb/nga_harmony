{
  "name": "nga-oh",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy:assets": "node scripts/copy-assets.js",
    "dev": "npm run copy:assets && concurrently \"tsx watch src/server/index.ts\" \"vite --config src/client/web/vite.config.ts\"",
    "dev:client": "vite --config src/client/web/vite.config.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build --config src/client/web/vite.config.ts && npm run copy:assets",
    "build": "npm run build:server && npm run build:client",
    "kill": "node scripts/kill-port.js",
    "restart": "npm run kill && npm run dev",
    "start": "node dist/server/index.js"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "framer-motion": "^12.38.0",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  }
}
